# ==============================================================================
# Phase 5 — .env.example: Production Environment Configuration Templates
# ==============================================================================

# Core Application Settings
PYTHONUNBUFFERED=1
PORT=8501
HOST=0.0.0.0

# Inactivity Session Auto-Timeout Boundary (in minutes, standard is 15)
SESSION_TIMEOUT_MINUTES=15

# Security Sandbox File Upload Caps (in megabytes, standard is 500MB)
MAX_UPLOAD_SIZE_MB=500

# Streamlit Aesthetic Light-Theme Bindings
STREAMLIT_THEME_BASE=light
STREAMLIT_THEME_PRIMARYCOLOR=#4f46e5
STREAMLIT_THEME_BACKGROUNDCOLOR=#f8fafc
STREAMLIT_THEME_SECONDARYBACKGROUNDCOLOR=#f1f5f9
STREAMLIT_THEME_TEXTCOLOR=#1e293b

# PyTorch Optimization Device Override (e.g. cuda, mps, cpu - auto-detected by default)
DEVICE_OVERRIDE=auto
